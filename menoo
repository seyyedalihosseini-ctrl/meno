                </div>
            </div>

            <!-- ===== دسته ۵: بستنی و دشر ===== -->
            <div class="category-panel" data-cat="5" style="display:none;">
                <div class="category-title"><span class="icon">🍰</span> بستنی و دشر</div>
                <div class="category-items">
                    <div class="menu-item"><span class="name">بستنی لیوانی نوتلا</span><span class="price">۲۱۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">دشر میوه‌ای</span><span class="price">۲۸۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">دشر بیسکوییتی</span><span class="price">۲۸۵ <small>تومان</small></span></div>
