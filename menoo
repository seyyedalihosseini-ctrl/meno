                    <div class="menu-item"><span class="name">سوشی نوتلا</span><span class="price">۳۱۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">کرپ اسپیشیال نوتلا</span><span class="price">۳۳۵ <small>تومان</small></span></div>
                </div>
            </div>

            <!-- ===== دسته ۴: پنکیک‌ها ===== -->
            <div class="category-panel" data-cat="4" style="display:none;">
                <div class="category-title"><span class="icon">🥞</span> پنکیک‌ها</div>
                <div class="category-items">
                    <div class="menu-item"><span class="name">پنکیک نوتلا</span><span class="price">۲۳۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">پنکیک بستنی نوتلا</span><span class="price">۲۹۵ <small>تومان</small></span></div>
