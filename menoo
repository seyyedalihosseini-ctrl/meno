                    <div class="menu-item"><span class="name">پنکیک اورئو</span><span class="price">۲۸۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">پنکیک اورئو فندق</span><span class="price">۳۳۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">پنکیک کره بادام زمینی</span><span class="price">۲۷۵ <small>تومان</small></span></div>
