            <!-- ===== دسته ۷: شیک‌ها ===== -->
            <div class="category-panel" data-cat="7" style="display:none;">
                <div class="category-title"><span class="icon">🥤</span> شیک‌ها</div>
                <div class="category-items">
                    <div class="menu-item"><span class="name">شیک نوتلا</span><span class="price">۲۱۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">شیک بیسکوئیت نوتلا</span><span class="price">۲۲۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">شیک موز نوتلا</span><span class="price">۲۴۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">شیک توت فرنگی نوتلا</span><span class="price">۲۴۵ <small>تومان</small></span></div>
