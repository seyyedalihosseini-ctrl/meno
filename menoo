                <span class="icon">🥞</span> پنکیک‌ها
            </button>
            <button class="cat-btn" data-cat="5">
                <span class="icon">🍰</span> بستنی و دشر
            </button>
            <button class="cat-btn" data-cat="6">
                <span class="icon">🍡</span> موچی‌ها
            </button>
            <button class="cat-btn" data-cat="7">
                <span class="icon">🥤</span> شیک‌ها
            </button>
            <button class="cat-btn" data-cat="8">
                <span class="icon">🧊</span> نوشیدنی‌های سرد
            </button>
            <button class="cat-btn" data-cat="9">
                <span class="icon">☕</span> نوشیدنی‌های گرم
            </button>
        </nav>

        <!-- ===== محتوای محصولات ===== -->
        <main class="content" id="content">

            <!-- ===== دسته ۰: وافل بستنی ===== -->
            <div class="category-panel" data-cat="0">
                <div class="category-title"><span class="icon">🍦</span> وافل بستنی</div>
                <div class="category-items">
                    <div class="menu-item"><span class="name">وافل بستنی ساده</span><span class="price">۲۶۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">وافل بستنی میوه‌ای</span><span class="price">۲۹۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">وافل بستنی بیسکوئیتی</span><span class="price">۲۹۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">وافل بستنی اسپیشیال</span><span class="price">۳۳۵ <small>تومان</small></span></div>
                </div>
            </div>

            <!-- ===== دسته ۱: وافل توپی ===== -->
            <div class="category-panel" data-cat="1" style="display:none;">
                <div class="category-title"><span class="icon">⚪</span> وافل توپی</div>
                <div class="category-items">
                    <div class="menu-item"><span class="name">وافل ۳ تایی نوتلا</span><span class="price">۱۶۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">وافل میوه‌ای ۶ تایی</span><span class="price">۲۶۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">وافل میوه‌ای ۱۲ تایی</span><span class="price">۲۸۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">وافل ۱۲ تایی ساده</span><span class="price">۲۳۵ <small>تومان</small></span></div>
                </div>
            </div>

            <!-- ===== دسته ۲: وافل مستطیلی ===== -->
            <div class="category-panel" data-cat="2" style="display:none;">
                <div class="category-title"><span class="icon">🧇</span> وافل مستطیلی</div>
                <div class="category-items">
                    <div class="menu-item"><span class="name">وافل نوتلا</span><span class="price">۲۳۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">وافل میوه‌ای نوتلا</span><span class="price">۲۶۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">وافل اورئو نوتلا</span><span class="price">۲۸۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">وافل فندقی نوتلا</span><span class="price">۳۱۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">وافل کره بادام زمینی</span><span class="price">۲۷۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">وافل اسپیشیال نوتلا</span><span class="price">۳۳۵ <small>تومان</small></span></div>
                </div>
            </div>

            <!-- ===== دسته ۳: کرپ‌ها ===== -->
            <div class="category-panel" data-cat="3" style="display:none;">
                <div class="category-title"><span class="icon">🥞</span> کرپ‌ها</div>
                <div class="category-items">
                    <div class="menu-item"><span class="name">کرپ نوتلا</span><span class="price">۲۳۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">کرپ بستنی نوتلا</span><span class="price">۲۶۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">کرپ میوه‌ای نوتلا</span><span class="price">۲۶۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">کرپ میوه‌ای بستنی نوتلا</span><span class="price">۲۹۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">کرپ اورئو نوتلا</span><span class="price">۲۸۵ <small>تومان</small></span></div>
