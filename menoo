                    <div class="menu-item"><span class="name">شیک اورئو</span><span class="price">۲۶۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">شیک اسنیکرز</span><span class="price">۲۸۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">شیک مارس</span><span class="price">۲۸۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">شیک کیت کت</span><span class="price">۲۸۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">شیک نسکافه</span><span class="price">۲۶۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">شیک لته</span><span class="price">۲۹۵ <small>تومان</small></span></div>
                    <div class="menu-item"><span class="name">شیک کارامل</span><span class="price">۲۹۵ <small>تومان</small></span></div>
