    <script>
        (function() {
            'use strict';

            const sidebar = document.getElementById('sidebar');
            const content = document.getElementById('content');
            const catBtns = sidebar.querySelectorAll('.cat-btn');
            const panels = content.querySelectorAll('.category-panel');

            // ===== تابع تغییر دسته =====
            function switchCategory(index) {
                catBtns.forEach((btn, i) => {
                    btn.classList.toggle('active', i === index);
                });
                panels.forEach((panel, i) => {
                    panel.style.display = (i === index) ? 'block' : 'none';
                });
            }

            // ===== کلیک روی دکمه‌های دسته =====
            catBtns.forEach((btn) => {
                btn.addEventListener('click', function(e) {
                    const index = parseInt(this.dataset.cat, 10);
                    if (!isNaN(index)) {
                        switchCategory(index);
                    }
                });
            });

            // ===== تنظیم اولیه =====
            switchCategory(0);

            // ===== اسکرول خودکار به بالای محتوا هنگام تغییر دسته (موبایل) =====
            catBtns.forEach((btn) => {
                btn.addEventListener('click', function() {
                    if (window.innerWidth <= 768) {
                        content.scrollTop = 0;
                    }
                });
            });

            console.log('🍫 منوی نوتلا بار با موفقیت بارگذاری شد!');
            console.log('📞 شماره تماس: ۰۹۰۳۲۰۴۳۲۳۳');
        })();
    </script>

