            <!-- ===== دسته ۶: موچی‌ها ===== -->
            <div class="category-panel" data-cat="6" style="display:none;">
                <div class="category-title"><span class="icon">🍡</span> موچی‌ها</div>
                <div class="category-items">
                    <div class="menu-item"><span class="name">موچی نوتلا</span><span class="price">۱۲۵ <small>تومان</small></span></div>
